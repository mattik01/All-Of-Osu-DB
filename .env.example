# --- Layer A: MySQL managed by Eve-ning/osu-data ---
# osu-data spins its own MySQL in Docker. These match its defaults; override
# only if you change the -p (port) flag when invoking osu-data.
LAYER_A_MYSQL_HOST=127.0.0.1
LAYER_A_MYSQL_PORT=3308
LAYER_A_MYSQL_USER=root
LAYER_A_MYSQL_PASSWORD=
LAYER_A_MYSQL_DB=osu

# Default osu-data invocation parameters. Override per-run on the CLI.
LAYER_A_MODE=osu
LAYER_A_VERSION=top_10000
# Monthly dump date in osu-data's format (YYYY_MM_DD). Leave blank to use
# osu-data's default (latest available).
LAYER_A_YMD=

# --- Layer B: local Postgres (our own docker-compose service) ---
LAYER_B_PG_HOST=127.0.0.1
LAYER_B_PG_PORT=5432
LAYER_B_PG_USER=osu
LAYER_B_PG_PASSWORD=change_me_local_only
LAYER_B_PG_DB=all_of_osu

# --- Optional future sources (unused in v1) ---
# OSU_API_V2_CLIENT_ID=
# OSU_API_V2_CLIENT_SECRET=
# OSU_TRACK_BASE_URL=https://osutrack-api.ameo.dev
