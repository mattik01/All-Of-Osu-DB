# --- Layer A: MySQL managed by Eve-ning/osu-data ---
# osu-data spins its own MySQL in Docker. These match its defaults; override
# only if you change the -p (port) flag when invoking osu-data.
LAYER_A_MYSQL_HOST=127.0.0.1
LAYER_A_MYSQL_PORT=3308
LAYER_A_MYSQL_USER=root
LAYER_A_MYSQL_PASSWORD=
LAYER_A_MYSQL_DB=osu

# Default osu-data invocation parameters. Override per-run on the CLI.
LAYER_A_MODE=osu
LAYER_A_VERSION=top_10000
# Monthly dump date in osu-data's format (YYYY_MM_DD). Leave blank to use
# osu-data's default (latest available).
LAYER_A_YMD=

# --- Layer B: local Postgres (our own docker-compose service) ---
LAYER_B_PG_HOST=127.0.0.1
LAYER_B_PG_PORT=5432
LAYER_B_PG_USER=osu
LAYER_B_PG_PASSWORD=change_me_local_only
LAYER_B_PG_DB=all_of_osu

# --- Layer A: Liquipedia tournament mappool scraper ---
# Liquipedia ToS requires a custom User-Agent identifying the project +
# contact email. Override here to set your own contact. Default is fine for
# personal/private use.
LIQUIPEDIA_USER_AGENT=All-Of-Osu-DB/0.1 (https://github.com/mattik01/All-Of-Osu-DB; glaeser.matteo@googlemail.com)
# Where to write scraped JSON (gitignored). One subdirectory per tournament.
LIQUIPEDIA_OUTPUT_DIR=data/layerA/liquipedia
# On-disk cache of MediaWiki API responses (also gitignored).
LIQUIPEDIA_CACHE_DIR=data/layerA/liquipedia/_cache
# Local SQLite sink for the verified Liquipedia scrape (Layer A raw mirror).
LIQUIPEDIA_SQLITE_PATH=data/layerA/liquipedia/liquipedia.sqlite
# Minimum seconds between `parse` API calls. Liquipedia ToS = 30s; do not
# lower without permission from Liquipedia staff.
LIQUIPEDIA_MIN_REQUEST_INTERVAL_S=30.0

# --- osu! API v2 ---
# Register a new OAuth2 client at https://osu.ppy.sh/home/account/edit#new-oauth-application
# (any name, callback URL can be blank). Used for verifying scraped beatmap_ids
# against the live osu! catalogue.
OSU_CLIENT_ID=
OSU_CLIENT_SECRET=
# Where to cache the access token (gitignored).
OSU_API_TOKEN_CACHE=data/layerA/osu_api_v2/_token.json
# Where to cache per-beatmap responses (gitignored).
OSU_API_RESPONSE_CACHE_DIR=data/layerA/osu_api_v2/_cache

# --- Optional future sources (unused in v1) ---
# OSU_TRACK_BASE_URL=https://osutrack-api.ameo.dev
